<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvAuditTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="数运审核"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCountyStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未启动"
            android:textSize="13sp"
            android:textColor="#6B7280" />
    </LinearLayout>

    <!-- 审核控制面板（紧凑布局） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@android:color/white"
        android:layout_marginTop="6dp">

        <!-- 区县选择 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择区县:"
                android:textSize="13sp"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinnerCounty"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_spinner"
                android:padding="6dp" />
        </LinearLayout>

        <!-- 审核按钮行（紧凑排列） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCountyAudit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="开始县级审核"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#F59E0B" />

            <Button
                android:id="@+id/btnStopCountyAudit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="停止"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EF4444"
                android:enabled="false" />

            <Button
                android:id="@+id/btnCityAudit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="开始市级审核"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#8B5CF6" />

            <Button
                android:id="@+id/btnStopCityAudit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="停止"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EF4444"
                android:enabled="false" />

            <Button
                android:id="@+id/btnProvinceAudit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="省级审核"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#10B981" />

            <Button
                android:id="@+id/btnStopProvinceAudit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="停止"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EF4444"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- 功能说明（单行紧凑显示） -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="4dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="#EFF6FF">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="县:自动/市:自动/省:手动，需开发者权限"
            android:textSize="10sp"
            android:textColor="#3B82F6"
            android:padding="6dp" />
    </androidx.cardview.widget.CardView>

    <!-- 市级已办列表（只显示省监控审核工单） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ECFDF5"
        android:layout_marginTop="4dp"
        android:padding="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="省监控待回单"
                android:textSize="11sp"
                android:textColor="#059669"
                android:textStyle="bold" />

            <!-- 省监控审核回单按钮 -->
            <Button
                android:id="@+id/btnProvinceMonitorAudit"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="回单"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EF4444"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />
        </LinearLayout>

        <!-- 可点击的已办列表 -->
        <ListView
            android:id="@+id/lvCityFinishedList"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="2dp"
            android:divider="#059669"
            android:dividerHeight="1dp"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/tvCityFinishedList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无省监控工单"
            android:textSize="9sp"
            android:textColor="#047857"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- 日志区域（加大高度） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1F2937"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="审核日志"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#111827" />

        <ScrollView
            android:id="@+id/svAuditLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvAuditLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#E5E7EB"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.15" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
