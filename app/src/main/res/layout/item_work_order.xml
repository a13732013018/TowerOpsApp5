<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/background_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 第一行：序号 + 工单号 + 告警状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvIndex"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/text_tertiary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvBillSn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="工单号"
                android:textColor="@color/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="告警中"
                android:textColor="@color/warning"
                android:textSize="12sp"
                android:background="@drawable/bg_tag_warning"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- 第二行：站点 + 标题 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="站点名 - 工单标题"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"/>

        <!-- 第三行：接单人 + 创建时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAcceptOp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="接单人：-"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="4dp"/>

            <TextView
                android:id="@+id/tvCreateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="创建：-"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp"/>

        <!-- 第四行：最近处理信息 -->
        <TextView
            android:id="@+id/tvDealInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/success"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:drawableStart="@drawable/ic_check_circle"
            android:drawablePadding="6dp"/>

        <!-- 第五行：工单历时 -->
        <TextView
            android:id="@+id/tvTimeDiff2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="工单历时：0分钟"
            android:textColor="@color/info"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"
            android:drawableStart="@drawable/ic_time"
            android:drawablePadding="6dp"/>

        <!-- 第六行：上次反馈时间 -->
        <TextView
            android:id="@+id/tvTimeDiff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上次反馈：尚未反馈"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <!-- 第七行：告警发生时间 -->
        <TextView
            android:id="@+id/tvAlertTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/warning"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"
            android:drawableStart="@drawable/ic_warning"
            android:drawablePadding="6dp"/>

        <!-- 第八行：当前状态 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--排队等待处理中..."
            android:textColor="@color/warning"
            android:textSize="13sp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
